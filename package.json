{
  "name": "civicmind",
  "version": "1.0.0",
  "description": "CivicMind — Digital Citizenship Platform",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
